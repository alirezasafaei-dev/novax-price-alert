APP_NAME=iran-market-price-alert
ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql+asyncpg://price_alert:change_me@127.0.0.1:5432/price_alert
REDIS_URL=redis://127.0.0.1:6379/0

TELEGRAM_BOT_TOKEN=
TELEGRAM_RELAY_URL=
TELEGRAM_RELAY_SECRET=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
TELEGRAM_SEND_TIMEOUT_SECONDS=10

ALANCHAND_API_TOKEN=
ALANCHAND_BASE_URL=https://api.alanchand.com
API_IR_API_KEY=
API_IR_BASE_URL=
BONBAST_BASE_URL=https://bonbast.com
NERKH_API_KEY=
NERKH_BASE_URL=https://api.nerkh.io
TGJU_BASE_URL=https://www.tgju.org

PROVIDER_CACHE_TTL_SECONDS=120
STALE_PRICE_SECONDS=300
WORKER_INTERVAL_SECONDS=60
NOTIFICATION_INTERVAL_SECONDS=5
USE_MOCK_PROVIDER=false
USE_MOCK_NOTIFICATIONS=false
ADMIN_ACCESS_TOKEN=your_very_long_random_admin_secret_here
