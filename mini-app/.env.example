# GEMINI_API_KEY: Required for the NovaX AI Financial Analyst (server-side only).
# Get one from https://aistudio.google.com/app/apikey
# Never commit real keys. For local dev put in .env (or .env.local).
GEMINI_API_KEY="your_gemini_api_key_here"

# For "Live Data" mode in the studio (toggle in the UI):
# When enabled, the price board pulls real prices and the manual slider
# calls the real backend's test override endpoint (affects LatestPrice for testing real alerts).
# VITE_ prefix makes it available to the Vite client bundle.
VITE_NOVAX_API_BASE="http://localhost:8001"

# (Optional) Full backend URL for server-side parts if you extend the Express server
# NOVAX_API_BASE="http://localhost:8001"

# TELEGRAM_INIT_DATA=...                   # automatically captured when opened as real Telegram WebApp

# Optional: when deploying this mini-app separately
PORT=3000
NODE_ENV=development

# GEMINI_API_KEY for the AI analyst tab (server-side only, never exposed to browser)
